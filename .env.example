# Copy this file to .env.local for local development.
# Image generation uses Pollinations.ai (free, no API key required).

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sui network: testnet | mainnet | devnet
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Deployed surprise_planner Move package
NEXT_PUBLIC_CARDJOY_PACKAGE_ID=0x01d4cb537283a740ddc9d9fa7c82a30baad22442dd41e109d8da0f2e0501a3d9

# Treasury that receives the per-generation fee
NEXT_PUBLIC_CARDJOY_TREASURY=0xe20a2d411c71f459bb53a57c5c4826c0fde97868ee2ae1cfc0954a9bb5c54957

# Fee per AI collage generation, in MIST (1 SUI = 1_000_000_000 MIST)
NEXT_PUBLIC_CARDJOY_FEE_MIST=10000000

# Walrus decentralized storage (testnet)
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Hugging Face API token (SERVER-SIDE ONLY — no NEXT_PUBLIC_ prefix).
# Used to call FLUX.1-schnell via the HF Inference router. Free tier
# is enough for hackathon-scale traffic. Get one at:
#   https://huggingface.co/settings/tokens  (Read access is enough)
# HUGGINGFACE_API_KEY=
